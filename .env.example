# ============================================================
# OISignalFlow v1.0.0 — Configuration Template (.env.example)
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git — it is already in .gitignore.

# ── Telegram (required) ─────────────────────────────────────
# Get token   : https://t.me/BotFather  →  /newbot
# Get chat ID : https://t.me/userinfobot  →  /start
TELEGRAM_TOKEN=1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefgh
TELEGRAM_CHAT_ID=123456789

# ── Scan Parameters ─────────────────────────────────────────
# Signal is triggered only when ALL four conditions are met:
OI_CHANGE_MIN=2.0          # OI must rise by at least X%
PRICE_CHANGE_MIN=0.3       # Price must rise by at least X%
VOLUME_MULT=1.5            # Volume must be X times the previous candle
SCAN_INTERVAL=5            # Scan every X minutes (5 = one candle)

# ── Rate Limiting ────────────────────────────────────────────
# Delay between NSE API requests in seconds.
# 0.3 = 300ms — safe default; reducing below 0.1 risks IP throttle.
REQUEST_DELAY=0.3

# ── ADX Trend Filter ─────────────────────────────────────────
# ADX measures trend strength. Filters out choppy/sideways stocks.
# Set ENABLE_ADX_FILTER=True to activate (recommended for volatile markets).
# ADX_MIN=25 means only stocks in strong trends pass the filter.
ENABLE_ADX_FILTER=False
ADX_MIN=25.0

# ── Output ──────────────────────────────────────────────────
OUTPUT_FILE=OISignalFlow_Results.xlsx

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO              # DEBUG / INFO / WARNING / ERROR
ENABLE_DESKTOP_NOTIFICATIONS=True   # Set False on servers (no desktop)

# ============================================================
# NOTE: FNO Stocks are automatically fetched from:
# https://nse-result-calendar.netlify.app/api/fno-list
# Falls back to 40 hardcoded stocks if API is unavailable.
# ============================================================
