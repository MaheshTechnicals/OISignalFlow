# ============================================================
# OISignalFlow Configuration Template (.env.example)
# ============================================================
# This is a template file. Copy to .env and fill in your values
# DO NOT commit your .env file with real tokens!

# Get your Telegram token from: https://t.me/BotFather
# Get your Chat ID from: https://t.me/userinfobot (send /start)
TELEGRAM_TOKEN=1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefgh
TELEGRAM_CHAT_ID=123456789

# Scan settings
OI_CHANGE_MIN=2.0
PRICE_CHANGE_MIN=0.3
VOLUME_MULT=1.5
SCAN_INTERVAL=5

# Output file
OUTPUT_FILE=OISignalFlow_Results.xlsx

# Logging
LOG_LEVEL=INFO
ENABLE_DESKTOP_NOTIFICATIONS=True
