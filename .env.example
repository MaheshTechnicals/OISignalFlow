# ============================================================
# OISignalFlow v1.0.0 — Configuration Template (.env.example)
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git — it is already in .gitignore.

# ⚠️  IMPORTANT: Do NOT put inline comments on value lines!
# WRONG:  OI_CHANGE_MIN=2.0     # some comment  ← CRASHES!
# CORRECT: OI_CHANGE_MIN=2.0                    ← WORKS!
# Put comments on their own separate line above the value.

# ── Telegram (required) ─────────────────────────────────────
# Get token   : https://t.me/BotFather  →  /newbot
# Get chat ID : https://t.me/userinfobot  →  /start
TELEGRAM_TOKEN=1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefgh
TELEGRAM_CHAT_ID=123456789

# ── Scan Parameters ─────────────────────────────────────────
# Signal is triggered only when ALL conditions are met:
OI_CHANGE_MIN=2.0          # OI must rise by at least X%
PRICE_CHANGE_MIN=0.3       # Price must rise by at least X%
VOLUME_MULT=1.5            # Volume must be X times the previous candle
SCAN_INTERVAL=5            # Scan every X minutes (5 = one candle)
CONFIRM_SCANS=2            # Stock must appear in X consecutive scans before alert
MIN_STOCK_PRICE=200.0      # Skip stocks below this price (illiquid CE options)
MIN_OI_CONTRACTS=50000     # Minimum absolute OI contracts required

# ── Signal Cooldown ──────────────────────────────────────────
SIGNAL_COOLDOWN_MINUTES=30 # Minutes before same stock can alert again

# 🔴 PE Signal Settings ───────────────────────────────────────
# Enable PE (Put Option) buy signal detection.
# PE signals are triggered by SHORT BUILDUP:
# Price falling + OI rising = new shorts entering
ENABLE_PE_SIGNALS=True
PE_PRICE_CHANGE_MIN=0.3    # Price must DROP by at least this %

# ── Rate Limiting ────────────────────────────────────────────
# Delay between NSE API requests in seconds.
# 0.3 = 300ms — safe default; reducing below 0.1 risks IP throttle.
REQUEST_DELAY=0.3

# ── ADX Trend Filter ─────────────────────────────────────────
# ADX measures trend strength. Filters out choppy/sideways stocks.
# Set ENABLE_ADX_FILTER=True to activate (recommended for volatile markets).
# ADX_MIN=25 means only stocks in strong trends pass the filter.
ENABLE_ADX_FILTER=False
ADX_MIN=25.0
ADX_PERIOD=14      # ADX calculation period (14 = industry standard, do not change unless you know why)

# ── PCR Market Filter ────────────────────────────────────────
# PCR = Put Call Ratio. Filters CE signals based on
# overall market sentiment before each scan.
# PCR < 0.8  = Very Bullish → CE signals allowed
# PCR 0.8–1.2 = Neutral    → CE signals allowed
# PCR > 1.2  = Bearish     → CE signals blocked
# Set ENABLE_PCR_FILTER=False to disable this filter.
ENABLE_PCR_FILTER=False
PCR_MAX=1.2              # Block CE signals if PCR above this value
PCR_URL=https://www.nseindia.com/api/option-chain-indices?symbol=NIFTY

# ── Time Window Filter ───────────────────────────────────────
# Only send Telegram CE alerts during best trading windows.
# Signals are always shown on dashboard regardless of time.
# Window 1: 9:30–11:30 AM (best — fresh trend forming)
# Window 2: 2:00–2:45 PM (second — closing momentum)
# Scanning still happens every 5 min outside windows
# but Telegram alerts are suppressed outside windows.
ENABLE_TIME_FILTER=True
WINDOW1_START=09:30
WINDOW1_END=11:30
WINDOW2_START=14:00
WINDOW2_END=14:45

# ── Output ──────────────────────────────────────────────────
OUTPUT_FILE=OISignalFlow_Results.xlsx

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO              # DEBUG / INFO / WARNING / ERROR
ENABLE_DESKTOP_NOTIFICATIONS=True   # Set False on servers (no desktop)

# ============================================================
# NOTE: FNO Stocks are automatically fetched from:
# https://nse-result-calendar.netlify.app/api/fno-list
# Falls back to 40 hardcoded stocks if API is unavailable.
# ============================================================
